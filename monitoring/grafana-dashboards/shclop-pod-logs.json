{
  "uid": "shclop-pod-logs",
  "title": "Shclop — Pod Logs",
  "tags": ["shclop", "logs"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "P8E80F9AEF21F6940"
        },
        "query": {
          "label": "service_name",
          "refId": "A",
          "type": 1
        },
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "refresh": 2,
        "sort": 1,
        "hide": 0
      },
      {
        "name": "search",
        "label": "Search",
        "type": "textbox",
        "query": "",
        "current": {
          "selected": false,
          "text": "",
          "value": ""
        },
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "title": "Log volume",
      "type": "timeseries",
      "datasource": {
        "type": "loki",
        "uid": "P8E80F9AEF21F6940"
      },
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 1,
            "showPoints": "never"
          },
          "unit": "short"
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["sum"]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "P8E80F9AEF21F6940"
          },
          "expr": "sum by(service_name) (count_over_time({service_name=~\"$service\"} |~ \"(?i)$search\" [$__auto]))",
          "legendFormat": "{{service_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Logs — $service",
      "type": "logs",
      "datasource": {
        "type": "loki",
        "uid": "P8E80F9AEF21F6940"
      },
      "gridPos": {
        "h": 26,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "P8E80F9AEF21F6940"
          },
          "expr": "{service_name=~\"$service\"} |~ \"(?i)$search\"",
          "refId": "A"
        }
      ]
    }
  ]
}
