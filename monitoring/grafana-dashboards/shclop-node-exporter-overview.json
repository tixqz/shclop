{
  "uid": "shclop-node-exporter-overview",
  "title": "Shclop Node Exporter Overview",
  "tags": ["shclop", "node-exporter"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": {"from": "now-1h", "to": "now"},
  "panels": [
    {"title": "Node CPU usage", "type": "timeseries", "datasource": "Prometheus", "gridPos": {"h": 6, "w": 8, "x": 0, "y": 0}, "targets": [{"expr": "100 * (1 - avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])))", "refId": "A"}]},
    {"title": "Node memory usage", "type": "timeseries", "datasource": "Prometheus", "gridPos": {"h": 6, "w": 8, "x": 8, "y": 0}, "targets": [{"expr": "100 * (1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes))", "refId": "A"}]},
    {"title": "Root filesystem usage", "type": "timeseries", "datasource": "Prometheus", "gridPos": {"h": 6, "w": 8, "x": 16, "y": 0}, "targets": [{"expr": "100 * (1 - (node_filesystem_avail_bytes{mountpoint=\"/\",fstype!~\"tmpfs|overlay\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!~\"tmpfs|overlay\"}))", "refId": "A"}]},
    {"title": "Load average", "type": "timeseries", "datasource": "Prometheus", "gridPos": {"h": 6, "w": 8, "x": 0, "y": 6}, "targets": [{"expr": "node_load1", "legendFormat": "1m", "refId": "A"}, {"expr": "node_load5", "legendFormat": "5m", "refId": "B"}, {"expr": "node_load15", "legendFormat": "15m", "refId": "C"}]},
    {"title": "Network receive/transmit", "type": "timeseries", "datasource": "Prometheus", "gridPos": {"h": 6, "w": 8, "x": 8, "y": 6}, "targets": [{"expr": "sum by (device) (rate(node_network_receive_bytes_total{device!~\"lo|veth.*|cni.*|flannel.*\"}[5m]))", "legendFormat": "rx {{device}}", "refId": "A"}, {"expr": "sum by (device) (rate(node_network_transmit_bytes_total{device!~\"lo|veth.*|cni.*|flannel.*\"}[5m]))", "legendFormat": "tx {{device}}", "refId": "B"}]},
    {"title": "Filesystem free bytes", "type": "timeseries", "datasource": "Prometheus", "gridPos": {"h": 6, "w": 8, "x": 16, "y": 6}, "targets": [{"expr": "node_filesystem_avail_bytes{mountpoint=\"/\",fstype!~\"tmpfs|overlay\"}", "refId": "A"}]},
    {"title": "Top pods by CPU", "type": "timeseries", "datasource": "Prometheus", "gridPos": {"h": 7, "w": 12, "x": 0, "y": 12}, "targets": [{"expr": "topk(10, sum by (namespace,pod) (rate(container_cpu_usage_seconds_total{container!=\"\",pod!=\"\"}[5m])))", "refId": "A"}]},
    {"title": "Top pods by memory", "type": "timeseries", "datasource": "Prometheus", "gridPos": {"h": 7, "w": 12, "x": 12, "y": 12}, "targets": [{"expr": "topk(10, sum by (namespace,pod) (container_memory_working_set_bytes{container!=\"\",pod!=\"\"}))", "refId": "A"}]}
  ]
}
