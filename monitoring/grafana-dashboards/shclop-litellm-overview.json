{
  "uid": "shclop-litellm-overview",
  "title": "Shclop LiteLLM Overview",
  "tags": [
    "shclop",
    "litellm"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "title": "LiteLLM up",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "efncoh2xlkhs0e"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "up{service=\"litellm\"} or vector(0)",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Requests/sec",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "efncoh2xlkhs0e"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(rate(litellm_proxy_total_requests_metric_total[5m])) or vector(0)",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Failures/sec",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "efncoh2xlkhs0e"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(rate(litellm_proxy_failed_requests_metric_total[5m])) or vector(0)",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Spend total",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "efncoh2xlkhs0e"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(litellm_spend_metric_total) or vector(0)",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Tokens/sec",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "efncoh2xlkhs0e"
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 5
      },
      "targets": [
        {
          "expr": "sum(rate(litellm_total_tokens_metric_total[5m])) or vector(0)",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Input/output tokens/sec",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "efncoh2xlkhs0e"
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 8,
        "y": 5
      },
      "targets": [
        {
          "expr": "sum(rate(litellm_input_tokens_metric_total[5m])) or vector(0)",
          "legendFormat": "input",
          "refId": "A"
        },
        {
          "expr": "sum(rate(litellm_output_tokens_metric_total[5m])) or vector(0)",
          "legendFormat": "output",
          "refId": "B"
        }
      ]
    },
    {
      "title": "LLM API p95 latency",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "efncoh2xlkhs0e"
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 16,
        "y": 5
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(litellm_llm_api_latency_metric_bucket[5m])) by (le)) or vector(0)",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Requests by model",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "efncoh2xlkhs0e"
      },
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 11
      },
      "targets": [
        {
          "expr": "sum by (model) (rate(litellm_proxy_total_requests_metric_total[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Tokens by model",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "efncoh2xlkhs0e"
      },
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 11
      },
      "targets": [
        {
          "expr": "sum by (model) (rate(litellm_total_tokens_metric_total[5m]))",
          "refId": "A"
        }
      ]
    }
  ]
}